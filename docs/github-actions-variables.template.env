# Copy this file to `docs/github-actions-variables.local.env`, fill the real values,
# then load it into GitHub Actions repository variables.
# Never commit the filled `.local.env` file.

WINDOWS_CERTIFICATE_THUMBPRINT=REPLACE_WITH_WINDOWS_CERTIFICATE_THUMBPRINT
WINDOWS_DIGEST_ALGORITHM=sha256
WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com
