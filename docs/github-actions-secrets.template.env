# Copy this file to `docs/github-actions-secrets.local.env`, fill the real values,
# then load it into GitHub Actions secrets.
# Never commit the filled `.local.env` file.

# macOS signing / notarization
APPLE_CERTIFICATE=BASE64_ENCODED_APPLE_P12_SINGLE_LINE
APPLE_CERTIFICATE_PASSWORD=REPLACE_WITH_APPLE_P12_EXPORT_PASSWORD
KEYCHAIN_PASSWORD=REPLACE_WITH_TEMPORARY_KEYCHAIN_PASSWORD
APPLE_ID=apple-id@example.com
APPLE_PASSWORD=REPLACE_WITH_APP_SPECIFIC_PASSWORD
APPLE_TEAM_ID=REPLACE_WITH_APPLE_TEAM_ID

# Windows signing
WINDOWS_CERTIFICATE=BASE64_ENCODED_WINDOWS_PFX_SINGLE_LINE
WINDOWS_CERTIFICATE_PASSWORD=REPLACE_WITH_WINDOWS_PFX_EXPORT_PASSWORD
